# =============================================================================
# Ask IRA — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Minimum to get started: set OPENAI_API_KEY (you have one)
# OR pick a free provider below (no credit card needed).
# =============================================================================

# =============================================================================
# 1. LLM PROVIDER (the brain of all 11 agents)
# =============================================================================
# Default: openai — uses GPT-4o via your API key
# To switch, set LLM_PROVIDER + the matching API key.
#
# PROVIDER       | LLM_PROVIDER=  | COST   | SIGN UP / INSTALL
# ---------------|----------------|--------|-----------------------------------------------------------
# OpenAI         | openai         | Your   | You already have a key
# Groq (FREE)    | groq           | $0     | https://console.groq.com (30 req/min, no credit card)
# Gemini (FREE)  | gemini         | $0     | https://aistudio.google.com (60 req/min)
# Ollama (FREE)  | ollama         | $0     | https://ollama.com (local, no API key)
# HuggingFace    | huggingface    | $0     | https://huggingface.co/settings/tokens
# OpenRouter     | openrouter     | $0     | https://openrouter.ai (200+ free models)
# DeepSeek       | deepseek       | ~$0    | https://platform.deepseek.com ($0.14/M tokens)
# Mistral (FREE) | mistral        | $0     | https://console.mistral.ai (free tier)
# Together AI    | together       | $0     | https://together.ai ($25 free credits)
# Fireworks AI   | fireworks      | $0     | https://fireworks.ai (free tier)
# Replicate      | replicate      | $0     | https://replicate.com (free trial credits)
# Anthropic      | anthropic      | Paid   | Paid key required
# =============================================================================

# --- Set your provider here ---
LLM_PROVIDER=openai

# --- Your OpenAI key (you have this) ---
OPENAI_API_KEY=

# --- FREE provider keys (only set the one matching LLM_PROVIDER) ---
GROQ_API_KEY=            # https://console.groq.com
GOOGLE_API_KEY=          # https://aistudio.google.com
HUGGINGFACE_API_KEY=     # https://huggingface.co/settings/tokens
OPENROUTER_API_KEY=      # https://openrouter.ai/keys
DEEPSEEK_API_KEY=        # https://platform.deepseek.com
MISTRAL_API_KEY=         # https://console.mistral.ai
TOGETHER_API_KEY=        # https://together.ai/api
FIREWORKS_API_KEY=       # https://fireworks.ai
REPLICATE_API_KEY=       # https://replicate.com

# --- Paid provider keys ---
# ANTHROPIC_API_KEY=

# =============================================================================
# 2. OBSERVABILITY (optional — LangSmith free tier: 100k obs/month)
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ask-ira

# =============================================================================
# 3. APPLICATION SETTINGS
# =============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
CHROMA_PERSIST_DIR=./data/chroma
CORS_ORIGINS=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
ENABLE_WEBSOCKET=true
ENABLE_HUMAN_REVIEW=false
CACHE_ENABLED=true

# =============================================================================
# 4. DATABASE (not needed — app uses built-in seed data)
# =============================================================================
# POSTGRES_DSN=

# =============================================================================
# 5. REDIS (not needed — falls back to in-memory cache)
# =============================================================================
# REDIS_URL=
REDIS_DEFAULT_TTL=300

# =============================================================================
# 7. JWT AUTHENTICATION
# =============================================================================
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=

# =============================================================================
# 8. MCP SERVER KEYS (not needed — all use built-in seed data)
# =============================================================================
# MCP_MARKET_API_KEY=
# MCP_NEWS_API_KEY=
