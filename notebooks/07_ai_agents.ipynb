   "source": ["# Session 7: AI Agents, Agentic AI & Deep Agents"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from langchain_core.tools import tool\n",
    "from langchain.agents import create_react_agent, AgentExecutor\n",
    "from langchain_core.prompts import PromptTemplate\n",
    "from src.utils.llm import get_llm\n",
    "\n",
    "llm = get_llm(temperature=0.0)\n",
    "print(\"Agent frameworks loaded\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. ReAct Agent with Tools"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@tool\n",
    def get_stock_price(ticker: str) -> str:\n",
    "    \"\"\"Get current stock price for a given ticker symbol.\"\"\"\n",
    "    prices = {\"AAPL\": 225, \"MSFT\": 420, \"GOOGL\": 175, \"AMZN\": 200}\n",
    "    return f\"${prices.get(ticker.upper(), 0)}\"\n",
    "\n",
    "@tool\n",
    "def calculate_pe_ratio(ticker: str, price: float, eps: float) -> str:\n",
    "    \"\"\"Calculate P/E ratio given price and earnings per share.\"\"\"\n",
    "    ratio = price / eps if eps > 0 else 0\n",
    "    return f\"P/E ratio: {ratio:.1f}x\"\n",
    "\n",
    "prompt = PromptTemplate.from_template(\n",
    "    \"Answer the following as best you can.\\n\\nQuestion: {input}\\n\\n{agent_scratchpad}\"\n",
    ")\n",
    "agent = create_react_agent(llm, [get_stock_price, calculate_pe_ratio], prompt)\n",
    "executor = AgentExecutor(agent=agent, tools=[get_stock_price, calculate_pe_ratio], verbose=True)\n",
    "\n",
    "result = executor.invoke({\"input\": \"What is AAPL's stock price and if EPS is $6.04, what's the P/E?\"})\n",
    "print(result[\"output\"])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Ask IRA Multi-Agent System"]
  },
