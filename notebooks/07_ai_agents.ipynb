  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Reflection Pattern (Self-Critique)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "async def reflect(report: str) -> str:\n",
    "    critique = await llm.ainvoke([\n",
    "        (\"system\", \"Critique this investment report. Identify gaps, biases, unsupported claims, and missing data.\"),\n",
    "        (\"human\", report)\n",
    "    ])\n",
    "    return critique.content\n",
    "\n",
    "sample = \"AAPL is a strong buy. The company has good products and will grow.\"\n",
    "critique = await reflect(sample)\n",
    "print(\"Critique:\")\n",
    "print(critique[:500])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Planning Agent (Decomposition)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "async def plan_research(query: str) -> str:\n",
    "    plan = await llm.ainvoke([\n",
    "        (\"system\", \"Decompose this investment question into sub-questions. Output as numbered list.\"),\n",
    "        (\"human\", query)\n",
    "    ])\n",
    "    return plan.content\n",
    "\n",
    "plan = await plan_research(\"Evaluate Tesla as a long-term investment\")\n",
    "print(plan)"
   ]
  }
